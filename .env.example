GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# If true, non-English transcripts are translated to English when possible.
TRANSCRIPT_AUTO_TRANSLATE_TO_EN=true

# If transcript API fails, fall back to downloading audio + Groq Whisper.
TRANSCRIPT_WHISPER_FALLBACK_ENABLED=true
TRANSCRIPT_WHISPER_MODEL=whisper-large-v3-turbo
